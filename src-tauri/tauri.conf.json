{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SymPony Music",
  "version": "1.2.0",
  "identifier": "moe.coiluck.kokone-music",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SymPony Music",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; ipc: http://ipc.localhost; media-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*", "$APPCACHE/**", "$APPDATA/**", "$APPLOCALDATA/**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
